NODE_ENV="production"

DB_HOST="mysql"
DB_PORT="3306"
DB_USER="mysql_user"
DB_PASS="mysql_password"
DB_NAME="podsmath"
MONGO_URI="mongodb://mongo_user:mongo_password@mongodb:27017/podsmath?authSource=admin"

JWT_SECRET="secret"

RESEND_API_KEY="api_key"

TRANSCRIPTION_SERVICE_PORT="3002"
USER_SERVICE_PORT="3001"
USER_SERVICE_URL="http://backend_user:3001"
FRONTEND_URL="https://podsmath.com.br"

# Variaveis para o Docker
MYSQL_ROOT_PASSWORD="mysql_root_password"
MYSQL_DATABASE="podsmath"
MYSQL_USER="mysql_user"
MYSQL_PASSWORD="mysql_password"

MONGO_INITDB_ROOT_USERNAME="mongo_user"
MONGO_INITDB_ROOT_PASSWORD="mongo_password"